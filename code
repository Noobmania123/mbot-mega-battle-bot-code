#include "src/OfflineBroadcast.h"
#include <Arduino.h>
#include <Wire.h>
#include <SoftwareSerial.h>
#include "src/MeSingleLineFollower.h"
#include "src/MeCollisionSensor.h"
#include "src/MeBarrierSensor.h"
#include "src/MeNewRGBLed.h"
#include <MeMegaPi.h>

#include <Arduino.h>
double angle_rad = PI/180.0;
double angle_deg = 180.0/PI;
MeCollisionSensor collision_65(65);
MeNewRGBLed rgbled_67(67,4);
MeCollisionSensor collision_66(66);
MeNewRGBLed rgbled_68(68,4);
MeSingleLineFollower linefollower_63(63);
MeMegaPiDCMotor motor_1(1);
MeMegaPiDCMotor motor_2(2);
MeMegaPiDCMotor motor_10(10);
MeMegaPiDCMotor motor_9(9);
MeMegaPiDCMotor motor_3(3);
MeMegaPiDCMotor motor_11(11);
MeMegaPiDCMotor motor_4(4);
MeMegaPiDCMotor motor_12(12);

OfflineBroadcast broadcaster;
void broadcastHandler(){
  // DO SOMETHING
  broadcaster.callOK();
}
void broadcastHandler1(){

  rgbled_67.setColor(0, 255,0,0);
  rgbled_67.show();

  rgbled_68.setColor(0, 255,0,0);
  rgbled_68.show();

  broadcaster.callOK();
}

void _delay(float seconds) {
  if(seconds < 0.0){
    seconds = 0.0;
  }
  long endTime = millis() + seconds * 1000;
  while(millis() < endTime) _loop();
}

void setup() {
  Serial.begin(115200);
  TCCR1A = _BV(WGM10);
  TCCR1B = _BV(CS11) | _BV(WGM12);
  TCCR2A = _BV(WGM21) | _BV(WGM20);
  TCCR2B = _BV(CS21);
  rgbled_67.fillPixelsBak(0, 2, 1);
  rgbled_68.fillPixelsBak(0, 2, 1);
  broadcaster.on(String("FIRING"),broadcastHandler);

  // DO SOMETHING

  broadcaster.on(String("FIRING"),broadcastHandler1);

  rgbled_67.setColor(0, 126,211,33);
  rgbled_67.show();

  rgbled_68.setColor(0, 126,211,33);
  rgbled_68.show();

  motor_1.run(50 / 100.0 * 255);
  motor_2.run(50 / 100.0 * 255);

  motor_9.run(-50 / 100.0 * 255);
  motor_10.run(-50 / 100.0 * 255);
  _delay(3);
  broadcaster.broadcast(String("FIRING"));

  motor_1.run(0);
  motor_9.run(0);
  motor_2.run(0);
  motor_10.run(0);
  motor_3.run(0);
  motor_11.run(0);
  motor_4.run(0);
  motor_12.run(0);
  _delay(3);

  motor_1.run(100 / 100.0 * 255);
  motor_2.run(100 / 100.0 * 255);

  motor_9.run(-100 / 100.0 * 255);
  motor_10.run(-100 / 100.0 * 255);
  _delay(3);

  motor_1.run(0);
  motor_9.run(0);
  motor_2.run(0);
  motor_10.run(0);
  motor_3.run(0);
  motor_11.run(0);
  motor_4.run(0);
  motor_12.run(0);

}

void _loop() {
  broadcaster.loop();
}

void loop() {
  if(collision_65.isCollision()){

    rgbled_67.setColor(1, 211,32,32);
    rgbled_67.show();

    rgbled_67.setColor(1, 211,32,32);
    rgbled_67.show();

  }
  if(collision_66.isCollision()){

    rgbled_68.setColor(1, 211,32,32);
    rgbled_68.show();

    rgbled_68.setColor(1, 211,32,32);
    rgbled_68.show();

  }
  if((linefollower_63.readSensor() == 0)){

    motor_1.run(50 / 100.0 * 255);
    motor_2.run(50 / 100.0 * 255);

    motor_2.run(50 / 100.0 * 255);
    motor_10.run(50 / 100.0 * 255);

  }

  _loop();
}
